import java.util.Scanner;
class Main{
    public static void main(String args[]){
        int mark;
        Scanner in =new Scanner(System.in);
        mark=in.nextInt();
        if (mark>=85&&mark<=100){
            System.out.print("A");
        }else if(mark>=75&&mark<85){
             System.out.print("B");
        }else if(mark>=65&&mark<75){
             System.out.print("C");
    }else if(mark>=0&&mark<65){
             System.out.print("D");
    }else{
        System.out.print("Invalid");
    }
}
}
